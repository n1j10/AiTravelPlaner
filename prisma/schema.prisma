generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     Int    @id @default(autoincrement())
  name   String
  userId String @unique
  role   String @default("user")
  email  String @unique

  @@map("users")
}

model Destination {
  id          Int     @id @default(autoincrement())
  name        String
  country     String
  city        String?
  description String?
  highlights  String?
  bestSeason  String? @map("best_season")
  activities  String?
  price       Int?
  duration    String?
  imageUrl    String? @map("image")

  @@map("destinations")
}

model Checkout {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String
  phone        String
  checkInDate  DateTime
  checkOutDate DateTime
  travelers    Int
  price        Int

  @@map("checkout")
}
